# Compose-level variables for ECS or other server deployments.
# Copy this file to .env in the project root and replace the example host.

NEXT_PUBLIC_API_URL=http://your-domain-or-ip
NEXT_PUBLIC_WS_URL=http://your-domain-or-ip
NEXTAUTH_URL=http://your-domain-or-ip
FRONTEND_URL=http://your-domain-or-ip
CORS_ORIGIN=http://your-domain-or-ip
INTERNAL_API_URL=http://backend:3000

# Optional overrides
DB_USER=postgres
DB_PASSWORD=postgres
