'use client'

import { useState, useEffect, useCallback } from 'react'
import { useParams, useRouter } from 'next/navigation'
import {
  Alert,
  Box,
  Typography,
  LinearProgress,
  Chip,
  Tabs,
  Tab,
  Paper,
  Container,
  Fade,
  Zoom,
  Collapse,
  Pagination,
} from '@mui/material'
import { Book } from '@mui/icons-material'
import { message } from '@/lib/message'
import { AITasksAPI } from '@/lib/api/ai-tasks'
import { apiFetch } from '@/lib/utils/api'
import { useTaskProgressPolling } from '@/lib/hooks/useTaskProgressPolling'
import { PageHeader } from '@/components/ui/page-header'
import { UnifiedButton } from '@/components/ui/unified-button'
import { GradientCard } from '@/components/ui/gradient-card'
import { StatusBadge } from '@/components/ui/status-badge'
import { ClauseAccordion, ClauseContent } from '@/components/ui/clause-accordion'
import {
  BookOpen,
  Lightbulb,
  ClipboardList,
  AlertTriangle,
  GraduationCap,
  Info as InfoIcon,
  Clock,
  CheckCircle2,
  AlertCircle,
  Play,
  RefreshCw,
  ArrowLeft,
  ChevronDown,
  ChevronUp,
} from 'lucide-react'

interface ReferenceInfo {
  standard_name: string
  standard_code?: string
  clause_id: string
  clause_summary: string
  issuing_authority?: string
  relation_type: 'REFERENCE' | 'SUPPLEMENT' | 'CONFLICT' | 'SYNERGY'
  relevance_score: number
}

interface InterpretationResult {
  overview: {
    background: string
    scope: string
    core_objectives: string[]
    target_audience: string[]
    key_changes?: string
  }
  key_terms: Array<{
    term: string
    definition: string
    explanation: string
    examples?: string[]
  }>
  key_requirements: Array<{
    clause_id: string
    chapter?: string
    clause_full_text?: string
    clause_summary?: string
    clause_text: string
    interpretation: string | {
      what: string
      why?: string
      how: string
    }
    compliance_criteria: string[] | {
      must_have: string[]
      should_have?: string[]
      evidence_required: string[]
      assessment_method: string
    }
    priority: 'HIGH' | 'MEDIUM' | 'LOW'
    references?: ReferenceInfo[]
  }>
  implementation_guidance: {
    preparation: string[]
    implementation_steps: Array<{
      phase: string
      steps: string[]
    }>
    best_practices: string[]
    common_pitfalls: string[]
    timeline_estimate: string
  }
}

interface TabPanelProps {
  children?: React.ReactNode
  value: number
  index: number
}

function TabPanel(props: TabPanelProps) {
  const { children, value, index, ...other } = props
  return (
    <Fade in={value === index} timeout={300}>
      <div
        role="tabpanel"
        hidden={value !== index}
        id={`interpretation-tabpanel-${index}`}
        aria-labelledby={`interpretation-tab-${index}`}
        {...other}
      >
        {value === index && <Box sx={{ py: 3 }}>{children}</Box>}
      </div>
    </Fade>
  )
}

export default function StandardInterpretationPage() {
  const params = useParams()
  const router = useRouter()
  const projectId = params.projectId as string

  const [loading, setLoading] = useState(false)
  const [initializing, setInitializing] = useState(true)
  const [result, setResult] = useState<InterpretationResult | null>(null)
  const [taskId, setTaskId] = useState<string | null>(null)
  const [error, setError] = useState<string | null>(null)
  const [activeTab, setActiveTab] = useState(0)
  const [documents, setDocuments] = useState<any[]>([])

  // 条款要求分页和展开状态
  const [expandedClauses, setExpandedClauses] = useState<Set<number>>(new Set())
  const [clausePage, setClausePage] = useState(1)
  const CLAUSES_PER_PAGE = 5

  // 使用轮询 hook 监听任务进度
  const { progress } = useTaskProgressPolling({
    taskId: taskId || undefined,
    enabled: !!taskId && loading && !result,
    pollingInterval: 5000,
    onComplete: async (status) => {
      if (status.status === 'completed') {
        try {
          const task = await AITasksAPI.getTask(taskId!)
          if (task && task.result) {
            // 解析标准解读结果
            let interpretationResult: InterpretationResult
            if (task.result.content) {
              try {
                interpretationResult = typeof task.result.content === 'string'
                  ? JSON.parse(task.result.content)
                  : task.result.content
              } catch (e) {
                console.error('Failed to parse result:', e)
                interpretationResult = task.result.content
              }
            } else if (task.result.gpt4 || task.result.claude || task.result.domestic) {
              interpretationResult = task.result.gpt4 || task.result.claude || task.result.domestic
            } else {
              interpretationResult = task.result
            }
            setResult(interpretationResult)
            setLoading(false)
            message.success('标准解读完成！')
          }
        } catch (err) {
          console.error('Failed to fetch result:', err)
          setError('获取解读结果失败')
          setLoading(false)
        }
      } else if (status.status === 'failed') {
        setError(status.message || '解读失败')
        setLoading(false)
      }
    },
  })

  // 加载项目文档
  const loadDocuments = useCallback(async () => {
    try {
      const response = await apiFetch(`/files/projects/${projectId}/documents/list`, {
        method: 'POST',
      })
      if (response.success) {
        setDocuments(response.data || [])
      }
    } catch (err) {
      console.error('Failed to load documents:', err)
    }
  }, [projectId])

  // 检查是否有已保存的解读任务
  const loadSavedTask = useCallback(async () => {
    try {
      const project = await apiFetch(`/projects/${projectId}`)

      // 从项目 metadata 获取文档列表（如果 loadDocuments 失败时的回退）
      const uploadedDocs = project.metadata?.uploadedDocuments || []
      if (uploadedDocs.length > 0) {
        setDocuments(uploadedDocs)
      }

      if (project.metadata?.standardInterpretationTaskId) {
        const savedTaskId = project.metadata.standardInterpretationTaskId
        setTaskId(savedTaskId)

        try {
          const task = await AITasksAPI.getTask(savedTaskId)
          if (task && task.status === 'completed' && task.result) {
            let interpretationResult: InterpretationResult
            if (task.result.content) {
              interpretationResult = typeof task.result.content === 'string'
                ? JSON.parse(task.result.content)
                : task.result.content
            } else if (task.result.gpt4 || task.result.claude || task.result.domestic) {
              interpretationResult = task.result.gpt4 || task.result.claude || task.result.domestic
            } else {
              interpretationResult = task.result
            }
            setResult(interpretationResult)
          } else if (task.status === 'processing' || task.status === 'pending') {
            // 检查任务是否卡住（超过120分钟没有更新）
            const taskUpdatedAt = new Date(task.updatedAt).getTime()
            const now = Date.now()
            const stuckThreshold = 120 * 60 * 1000 // 120分钟（大型文档解读可能需要80-90分钟）

            if (now - taskUpdatedAt > stuckThreshold) {
              // 任务卡住，显示错误并允许重新开始
              setError('解读任务似乎已卡住（超过120分钟无响应），请重新尝试')
              setLoading(false)
              // 清除项目中的卡住任务ID，允许用户重新创建任务
              await apiFetch(`/projects/${projectId}`, {
                method: 'PATCH',
                body: JSON.stringify({
                  metadata: {
                    standardInterpretationTaskId: null,
                  },
                }),
              })
              setTaskId(null)
            } else {
              setLoading(true)
            }
          } else if (task.status === 'failed') {
            // 任务失败，显示错误信息
            setError(task.errorMessage || '解读任务失败，请重试')
            setLoading(false)
            // 清除项目中的失败任务ID，允许用户重新创建任务
            await apiFetch(`/projects/${projectId}`, {
              method: 'PATCH',
              body: JSON.stringify({
                metadata: {
                  standardInterpretationTaskId: null,
                },
              }),
            })
            setTaskId(null)
          }
        } catch (err) {
          console.log('Failed to load saved task:', err)
        }
      }
    } catch (err) {
      console.error('Failed to load project:', err)
    } finally {
      setInitializing(false)
    }
  }, [projectId])

  useEffect(() => {
    loadDocuments()
    loadSavedTask()
  }, [loadDocuments, loadSavedTask])

  const handleAnalyze = async () => {
    try {
      setLoading(true)
      setError(null)

      // 获取项目信息
      const project = await apiFetch(`/projects/${projectId}`)
      const uploadedDocs = project.metadata?.uploadedDocuments || []

      if (uploadedDocs.length === 0) {
        setError('请先上传至少1个文档')
        setLoading(false)
        return
      }

      // 合并所有文档内容
      const documentsText = uploadedDocs.map((doc: any) =>
        `=== ${doc.name} ===\n\n${doc.content}`
      ).join('\n\n')

      if (!documentsText || documentsText.length < 100) {
        setError('文档内容太短，无法进行分析')
        setLoading(false)
        return
      }

      // 创建标准解读任务（使用两阶段批量模式处理大文档）
      const task = await AITasksAPI.createTask({
        projectId,
        type: 'standard_interpretation',
        input: {
          standardDocument: {
            id: uploadedDocs[0]?.id || 'doc-1',
            name: uploadedDocs[0]?.name || project.name || '标准文档',
            content: documentsText,
          },
          interpretationMode: 'enterprise',
          useTwoPhaseMode: true,  // 启用两阶段批量模式
          batchSize: 5,           // 每批处理5条条款
        },
      })

      setTaskId(task.id)

      // 保存 taskId 到项目 metadata
      await apiFetch(`/projects/${projectId}`, {
        method: 'PATCH',
        body: JSON.stringify({
          metadata: {
            standardInterpretationTaskId: task.id,
          },
        }),
      })
    } catch (err: any) {
      console.error('Failed to start analysis:', err)
      setError(err.message || '启动解读失败')
      setLoading(false)
    }
  }

  const getPriorityConfig = (priority: string) => {
    switch (priority) {
      case 'HIGH':
        return { label: '高优先级', status: 'error' as const, level: 'high' as const }
      case 'MEDIUM':
        return { label: '中优先级', status: 'warning' as const, level: 'medium' as const }
      case 'LOW':
        return { label: '低优先级', status: 'success' as const, level: 'low' as const }
      default:
        return { label: priority, status: 'info' as const, level: 'low' as const }
    }
  }

  const handleTabChange = (event: React.SyntheticEvent, newValue: number) => {
    setActiveTab(newValue)
  }

  // 条款展开/折叠处理
  const toggleClauseExpand = (index: number) => {
    const newExpanded = new Set(expandedClauses)
    if (newExpanded.has(index)) {
      newExpanded.delete(index)
    } else {
      newExpanded.add(index)
    }
    setExpandedClauses(newExpanded)
  }

  // 展开所有条款
  const expandAllClauses = () => {
    const allIndices = new Set(
      result?.key_requirements?.map((_, idx) => idx) || []
    )
    setExpandedClauses(allIndices)
  }

  // 折叠所有条款
  const collapseAllClauses = () => {
    setExpandedClauses(new Set())
  }

  if (initializing) {
    return (
      <Container maxWidth="xl" sx={{ py: 4 }}>
        <Box sx={{ display: 'flex', justifyContent: 'center', alignItems: 'center', minHeight: 400 }}>
          <Box sx={{ textAlign: 'center' }}>
            <LinearProgress sx={{ width: 200, mb: 2, borderRadius: 1 }} />
            <Typography color="text.secondary">加载中...</Typography>
          </Box>
        </Box>
      </Container>
    )
  }

  return (
    <Container maxWidth="xl" sx={{ py: 4 }}>
      {/* 页面头部 */}
      <PageHeader
        title="标准解读"
        description="基于上传的标准文档，AI智能解读条款要求"
        icon={<BookOpen className="w-6 h-6" />}
        actions={
          <UnifiedButton
            variant="ghost"
            size="md"
            onClick={() => router.back()}
            startIcon={<ArrowLeft className="w-4 h-4" />}
          >
            返回
          </UnifiedButton>
        }
        className="mb-8"
      />

      {error && (
        <Alert
          severity="error"
          icon={<AlertCircle />}
          className="mb-6 rounded-xl shadow-lg"
        >
          {error}
        </Alert>
      )}

      {!result ? (
        <GradientCard className="text-center py-12 px-6">
          {documents.length === 0 ? (
            <Alert
              severity="warning"
              icon={<InfoIcon />}
              className="mb-8 text-left rounded-xl max-w-[500px] mx-auto"
            >
              请先上传标准文档，然后才能进行标准解读
            </Alert>
          ) : (
            <Zoom in timeout={500}>
              <Box className="mb-8">
                <Box className="w-20 h-20 rounded-full bg-primary-100 flex items-center justify-center mx-auto mb-6">
                  <Book className="w-10 h-10 text-primary-600" />
                </Box>
                <Typography variant="h5" className="font-semibold mb-2">
                  已准备好 {documents.length} 个文档
                </Typography>
                <Typography variant="body2" color="text.secondary">
                  文档已就绪，点击下方按钮开始AI智能解读
                </Typography>
              </Box>
            </Zoom>
          )}

          <UnifiedButton
            variant="primary"
            size="lg"
            onClick={handleAnalyze}
            disabled={loading || documents.length === 0}
            loading={loading}
            startIcon={loading ? null : <Play className="w-5 h-5" />}
            className="px-8 py-4 text-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          >
            {loading ? '分析中...' : '开始解读'}
          </UnifiedButton>

          {loading && (
            <Box className="mt-8 max-w-[600px] mx-auto">
              <Paper className="p-6 rounded-2xl bg-gray-50">
                <LinearProgress className="mb-6 h-2 rounded-lg" />
                {progress ? (
                  <>
                    <Box className="flex items-center gap-2 mb-4">
                      <Clock className="text-primary-600 w-5 h-5" />
                      <Typography variant="h6" color="primary" className="font-semibold">
                        {progress.details?.phase === 'extraction'
                          ? '第一阶段：条款提取'
                          : progress.details?.phase === 'interpretation'
                            ? '第二阶段：批量解读'
                            : '分析中...'}
                      </Typography>
                    </Box>

                    <Box className="flex justify-between mb-4">
                      <Typography variant="body2" color="text.secondary">总体进度</Typography>
                      <Typography variant="body2" className="font-semibold">
                        {progress.progress?.gpt4?.status === 'completed'
                          ? '100%'
                          : `${progress.percentage || 0}%`}
                      </Typography>
                    </Box>

                    {progress.details?.totalClauses && progress.details.totalClauses > 0 && (
                      <Typography variant="body2" color="text.secondary" className="mb-4">
                        共识别 <strong>{progress.details?.totalClauses}</strong> 个条款
                        {progress.details?.totalBatches && progress.details.totalBatches > 0 && (
                          <>，分 <strong>{progress.details?.totalBatches}</strong> 批处理</>
                        )}
                      </Typography>
                    )}

                    {progress.details?.currentBatch && progress.details.currentBatch > 0 && progress.details?.totalBatches && progress.details.totalBatches > 0 && (
                      <Paper className="p-4 rounded-2xl bg-primary-50 mb-4 border border-primary-200">
                        <Typography variant="subtitle1" className="font-semibold text-primary-700 mb-2">
                          批次进度: {progress.details?.currentBatch} / {progress.details?.totalBatches}
                        </Typography>
                        <LinearProgress
                          variant="determinate"
                          value={(progress.details?.currentBatch / progress.details?.totalBatches) * 100}
                          className="mt-2 h-1.5 rounded-full bg-primary-200"
                        />
                        <Typography variant="caption" className="text-primary-700 mt-1 block">
                          已完成 {Math.round((progress.details?.currentBatch / progress.details?.totalBatches) * 100)}%
                        </Typography>
                      </Paper>
                    )}

                    {progress.stageMessage && (
                      <Typography variant="body2" color="text.secondary" className="mb-4">
                        {progress.stageMessage}
                      </Typography>
                    )}

                    <Alert
                      severity="info"
                      icon={<InfoIcon />}
                      className="rounded-xl text-left"
                    >
                      标准解读采用两阶段分析：先提取所有条款，再分批深度解读。根据文档复杂度，可能需要 30-90 分钟，请耐心等待。
                    </Alert>

                    <Box className="mt-6 text-center">
                      <UnifiedButton
                        variant="outline"
                        size="sm"
                        onClick={async () => {
                          if (confirm('确定要取消当前任务并重新开始吗？')) {
                            setLoading(false)
                            setTaskId(null)
                            await apiFetch(`/projects/${projectId}`, {
                              method: 'PATCH',
                              body: JSON.stringify({
                                metadata: { standardInterpretationTaskId: null },
                              }),
                            })
                          }
                        }}
                      >
                        任务卡住？点击重新开始
                      </UnifiedButton>
                    </Box>
                  </>
                ) : (
                  <>
                    <Typography variant="body2" color="text.secondary">正在获取进度信息...</Typography>
                    <Box className="mt-6 text-center">
                      <UnifiedButton
                        variant="outline"
                        size="sm"
                        onClick={async () => {
                          if (confirm('确定要取消当前任务并重新开始吗？')) {
                            setLoading(false)
                            setTaskId(null)
                            await apiFetch(`/projects/${projectId}`, {
                              method: 'PATCH',
                              body: JSON.stringify({
                                metadata: { standardInterpretationTaskId: null },
                              }),
                            })
                          }
                        }}
                      >
                        任务卡住？点击重新开始
                      </UnifiedButton>
                    </Box>
                  </>
                )}
              </Paper>
            </Box>
          )}
        </GradientCard>
      ) : (
        <>
          <GradientCard className="mb-4">
            <Box className="bg-white rounded-xl p-1.5 shadow-sm">
              <Box className="flex items-center justify-center gap-1 overflow-x-auto">
                {[{ label: '概述', icon: BookOpen }, { label: '关键术语', icon: GraduationCap }, { label: '条款要求', icon: ClipboardList }, { label: '实施指南', icon: Lightbulb }].map((tab, index) => (
                  <button
                    key={tab.label}
                    onClick={() => handleTabChange({} as React.SyntheticEvent, index)}
                    className={`
                      flex items-center gap-2 px-6 py-3 rounded-lg font-medium transition-all duration-200
                      ${activeTab === index
                        ? 'bg-gradient-to-r from-primary-600 to-purple-600 text-white shadow-lg shadow-primary-500/25'
                        : 'text-gray-500 hover:bg-primary-50 hover:text-gray-700'
                      }
                    `}
                  >
                    <tab.icon className="w-4 h-4" />
                    {tab.label}
                  </button>
                ))}
              </Box>
            </Box>
          </GradientCard>

          <GradientCard>
            {/* 概述 */}
            <TabPanel value={activeTab} index={0}>
              <h5 className="text-lg font-semibold mb-4 flex items-center gap-2">
                <InfoIcon className="w-5 h-5 text-primary-600" /> 标准概述
              </h5>

              <GradientCard className="mb-6">
                <h6 className="text-base font-semibold text-primary-600 mb-3">背景</h6>
                <p className="text-text-secondary leading-relaxed">
                  {result.overview?.background || '暂无信息'}
                </p>
              </GradientCard>

              <GradientCard className="mb-6">
                <h6 className="text-base font-semibold text-primary-600 mb-3">适用范围</h6>
                <p className="text-text-secondary leading-relaxed">
                  {result.overview?.scope || '暂无信息'}
                </p>
              </GradientCard>

              <GradientCard className="mb-6">
                <h6 className="text-base font-semibold text-primary-600 mb-3">核心目标</h6>
                <ul className="list-none pl-3 m-0">
                  {result.overview?.core_objectives?.map((obj, idx) => (
                    <li key={idx} className="mb-3 last:mb-0 flex items-center gap-2">
                      <CheckCircle2 className="w-4 h-4 text-success-600" />
                      <span className="text-text-primary">{obj}</span>
                    </li>
                  )) || <li className="text-text-primary">暂无信息</li>}
                </ul>
              </GradientCard>

              <GradientCard>
                <h6 className="text-base font-semibold text-primary-600 mb-3">目标受众</h6>
                <Box className="flex flex-wrap gap-2">
                  {result.overview?.target_audience?.map((aud, idx) => (
                    <Chip
                      key={idx}
                      label={aud}
                      color="primary"
                      variant="outlined"
                      className="rounded-xl"
                    />
                  )) || <span className="text-text-primary">暂无信息</span>}
                </Box>
              </GradientCard>
            </TabPanel>

            {/* 关键术语 */}
            <TabPanel value={activeTab} index={1}>
              <h5 className="text-lg font-semibold mb-4 flex items-center gap-2">
                <GraduationCap className="w-5 h-5 text-primary-600" /> 关键术语定义
              </h5>
              <Box className="flex flex-col gap-4">
                {result.key_terms?.map((term, idx) => (
                  <GradientCard key={idx} className="p-5 border-l-4 border-l-primary-500">
                    <h6 className="text-lg font-semibold text-primary-600 mb-3">
                      {term.term}
                    </h6>
                    <Box className="mb-3">
                      <span className="text-xs text-text-secondary font-medium mb-1 block">
                        定义
                      </span>
                      <p className="text-sm text-text-secondary">{term.definition}</p>
                    </Box>
                    <Box className="mb-3">
                      <span className="text-xs text-text-secondary font-medium mb-1 block">
                        解释
                      </span>
                      <p className="text-sm text-text-primary">{term.explanation}</p>
                    </Box>
                    {term.examples && term.examples.length > 0 && (
                      <Box>
                        <span className="text-xs text-text-secondary font-medium mb-1 block">
                          示例
                        </span>
                        <ul className="list-disc pl-5 m-0">
                          {term.examples.map((ex, i) => (
                            <li key={i} className="mb-1">
                              <span className="text-sm text-text-secondary">{ex}</span>
                            </li>
                          ))}
                        </ul>
                      </Box>
                    )}
                  </GradientCard>
                )) || <p className="text-text-primary">暂无术语定义</p>}
              </Box>
            </TabPanel>

            {/* 条款要求 */}
            <TabPanel value={activeTab} index={2}>
              <h5 className="text-lg font-semibold mb-4 flex items-center gap-2">
                <ClipboardList className="w-5 h-5 text-primary-600" /> 关键条款要求
              </h5>

              {result.key_requirements && result.key_requirements.length > 0 && (
                <>
                  {/* 批量操作按钮 */}
                  <Box className="flex gap-2 mb-4 flex-wrap">
                    <UnifiedButton
                      size="sm"
                      variant="outline"
                      onClick={expandAllClauses}
                      startIcon={<ChevronDown className="w-4 h-4" />}
                    >
                      展开全部
                    </UnifiedButton>
                    <UnifiedButton
                      size="sm"
                      variant="outline"
                      onClick={collapseAllClauses}
                      startIcon={<ChevronUp className="w-4 h-4" />}
                    >
                      折叠全部
                    </UnifiedButton>
                    <span className="ml-auto text-text-secondary flex items-center">
                      共 {result.key_requirements.length} 条条款
                    </span>
                  </Box>

                  {/* 条款列表 */}
                  <Box sx={{ display: 'flex', flexDirection: 'column', gap: 2, mb: 3 }}>
                    {result.key_requirements
                      .slice((clausePage - 1) * CLAUSES_PER_PAGE, clausePage * CLAUSES_PER_PAGE)
                      .map((req, idx) => {
                        const actualIndex = (clausePage - 1) * CLAUSES_PER_PAGE + idx
                        const priorityConfig = getPriorityConfig(req.priority)
                        const isExpanded = expandedClauses.has(actualIndex)

                        return (
                          <ClauseAccordion
                            key={actualIndex}
                            title={req.clause_summary || req.clause_text?.substring(0, 50) + '...'}
                            clauseNumber={req.clause_id}
                            priority={priorityConfig.level}
                            chapter={req.chapter}
                            defaultExpanded={isExpanded}
                            onExpandedChange={(expanded) => {
                              if (expanded) {
                                const newExpanded = new Set(expandedClauses)
                                newExpanded.add(actualIndex)
                                setExpandedClauses(newExpanded)
                              } else {
                                const newExpanded = new Set(expandedClauses)
                                newExpanded.delete(actualIndex)
                                setExpandedClauses(newExpanded)
                              }
                            }}
                          >
                            <ClauseContent
                              clauseText={req.clause_full_text || req.clause_text}
                              interpretation={
                                typeof req.interpretation === 'string'
                                  ? req.interpretation
                                  : req.interpretation?.what || '暂无解读'
                              }
                              compliance={
                                <Box component="ul" sx={{ pl: 3, m: 0 }}>
                                  {Array.isArray(req.compliance_criteria)
                                    ? req.compliance_criteria.map((criteria, i) => (
                                        <Box component="li" key={i} sx={{ mb: 1, '&:last-child': { mb: 0 } }}>
                                          <Typography variant="body2">{criteria}</Typography>
                                        </Box>
                                      ))
                                    : <Typography variant="body2">暂无具体要求</Typography>
                                  }
                                </Box>
                              }
                              references={
                                req.references && req.references.length > 0 && (
                                  <>
                                    {req.references.map((ref, i) => (
                                      <Box key={i} sx={{ mb: i < req.references!.length - 1 ? 2 : 0, p: 1.5, bgcolor: 'white', borderRadius: 1, border: '1px solid #e2e8f0' }}>
                                        <Typography variant="body2" fontWeight={600} color="#1e40af">
                                          《{ref.standard_name}》{ref.clause_id}
                                          {ref.standard_code && <span>（{ref.standard_code}）</span>}
                                        </Typography>
                                        {ref.issuing_authority && (
                                          <Typography variant="caption" color="text.secondary" display="block" sx={{ mt: 0.5 }}>
                                            发布机构：{ref.issuing_authority}
                                          </Typography>
                                        )}
                                        <Typography variant="body2" sx={{ mt: 0.5 }} color="text.secondary">
                                          {ref.clause_summary}
                                        </Typography>
                                        <Box sx={{ mt: 1, display: 'flex', gap: 1, alignItems: 'center' }}>
                                          <Chip
                                            label={
                                              ref.relation_type === 'REFERENCE' ? '引用' :
                                              ref.relation_type === 'SUPPLEMENT' ? '补充' :
                                              ref.relation_type === 'CONFLICT' ? '冲突' : '协同'
                                            }
                                            size="small"
                                            color={
                                              ref.relation_type === 'REFERENCE' ? 'primary' :
                                              ref.relation_type === 'SUPPLEMENT' ? 'success' :
                                              ref.relation_type === 'CONFLICT' ? 'error' : 'default'
                                            }
                                            variant="outlined"
                                            sx={{ height: 24 }}
                                          />
                                          <Typography variant="caption" color="text.secondary">
                                            关联度：{(ref.relevance_score * 100).toFixed(0)}%
                                          </Typography>
                                        </Box>
                                      </Box>
                                    ))}
                                  </>
                                )
                              }
                            />
                          </ClauseAccordion>
                        )
                      })}
                  </Box>

                  {/* 分页 */}
                  {result.key_requirements.length > CLAUSES_PER_PAGE && (
                    <Box sx={{ display: 'flex', justifyContent: 'center', mt: 3 }}>
                      <Pagination
                        count={Math.ceil(result.key_requirements.length / CLAUSES_PER_PAGE)}
                        page={clausePage}
                        onChange={(e, page) => {
                          setClausePage(page)
                          // 切换页面时折叠所有条款
                          setExpandedClauses(new Set())
                        }}
                        color="primary"
                        shape="rounded"
                        showFirstButton
                        showLastButton
                      />
                    </Box>
                  )}
                </>
              ) || <Typography variant="body1">暂无条款要求</Typography>}
            </TabPanel>

            {/* 实施指南 */}
            <TabPanel value={activeTab} index={3}>
              <h5 className="text-lg font-semibold mb-4 flex items-center gap-2">
                <Lightbulb className="w-5 h-5 text-primary-600" /> 实施指南
              </h5>

              <GradientCard className="mb-6">
                <h6 className="text-base font-semibold text-primary-600 mb-3">准备工作</h6>
                <ul className="list-none pl-3 m-0">
                  {result.implementation_guidance?.preparation?.map((item, idx) => (
                    <li key={idx} className="mb-3 last:mb-0 flex items-center gap-2">
                      <CheckCircle2 className="w-4 h-4 text-success-600" />
                      <span className="text-text-primary">{item}</span>
                    </li>
                  )) || <li className="text-text-primary">暂无信息</li>}
                </ul>
              </GradientCard>

              <GradientCard className="mb-6">
                <h6 className="text-base font-semibold text-primary-600 mb-3">实施步骤</h6>
                <Box className="flex flex-col gap-4">
                  {result.implementation_guidance?.implementation_steps?.map((step, idx) => (
                    <Paper key={idx} className="p-5 bg-gray-50 rounded-2xl border border-gray-200">
                      <Typography variant="subtitle1" className="font-semibold text-primary-600 mb-3 flex items-center gap-2">
                        <Box className="w-7 h-7 rounded-full bg-primary-600 text-white flex items-center justify-center text-sm font-semibold">
                          {idx + 1}
                        </Box>
                        {step.phase}
                      </Typography>
                      <ol className="list-decimal pl-6 m-0">
                        {step.steps?.map((s, i) => (
                          <li key={i} className="mb-2 last:mb-0">
                            <span className="text-sm text-text-primary">{s}</span>
                          </li>
                        ))}
                      </ol>
                    </Paper>
                  )) || <p className="text-text-primary">暂无实施步骤</p>}
                </Box>
              </GradientCard>

              <GradientCard className="mb-6">
                <h6 className="text-base font-semibold text-primary-600 mb-3">最佳实践</h6>
                <ul className="list-none pl-3 m-0">
                  {result.implementation_guidance?.best_practices?.map((item, idx) => (
                    <li key={idx} className="mb-3 last:mb-0 flex items-center gap-2">
                      <CheckCircle2 className="w-4 h-4 text-success-600" />
                      <span className="text-text-primary">{item}</span>
                    </li>
                  )) || <li className="text-text-primary">暂无信息</li>}
                </ul>
              </GradientCard>

              <GradientCard className="mb-6 bg-warning-50 border-warning-200">
                <h6 className="text-base font-semibold text-warning-700 mb-3">常见陷阱</h6>
                <ul className="list-none pl-3 m-0">
                  {result.implementation_guidance?.common_pitfalls?.map((item, idx) => (
                    <li key={idx} className="mb-3 last:mb-0 flex items-center gap-2 text-warning-700">
                      <AlertTriangle className="w-4 h-4 text-warning-600" />
                      <span className="text-text-primary">{item}</span>
                    </li>
                  )) || <li className="text-text-primary">暂无信息</li>}
                </ul>
              </GradientCard>

              <GradientCard>
                <h6 className="text-base font-semibold text-primary-600 mb-3">预计时间</h6>
                <Paper className="p-4 bg-success-50 rounded-2xl inline-flex items-center gap-2 border border-success-200">
                  <Clock className="text-success-600 w-4 h-4" />
                  <Typography variant="body1" className="font-medium text-success-700">
                    {result.implementation_guidance?.timeline_estimate || '暂无信息'}
                  </Typography>
                </Paper>
              </GradientCard>
            </TabPanel>
          </GradientCard>

          <Box className="mt-8 text-center">
            <UnifiedButton
              variant="outline"
              onClick={() => {
                setResult(null)
                setTaskId(null)
                setError(null)
              }}
              startIcon={<RefreshCw className="w-4 h-4" />}
              className="px-8 py-4 border-2"
            >
              重新解读
            </UnifiedButton>
          </Box>
        </>
      )}
    </Container>
  )
}
