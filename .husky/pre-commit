#!/usr/bin/env sh

hook_dir="${0%/*}"
if [ "$hook_dir" = "$0" ]; then
  hook_dir=".husky"
fi
. "$hook_dir/path-setup.sh"

repo_root="$(git rev-parse --show-toplevel)"

cd "$repo_root/frontend" || exit 1
node node_modules/lint-staged/bin/lint-staged.js || exit 1

cd "$repo_root/backend" || exit 1
node node_modules/lint-staged/bin/lint-staged.js || exit 1

cd "$repo_root" || exit 1
node backend/scripts/detect-orm-risk-changes.js --staged
orm_risk_status=$?

if [ "$orm_risk_status" -eq 10 ]; then
  echo "[husky] ORM 高风险 staged 改动 detected; running fast ORM guards"
  npm --workspace backend run orm:guard:fast || exit 1
elif [ "$orm_risk_status" -ne 0 ]; then
  exit "$orm_risk_status"
fi
