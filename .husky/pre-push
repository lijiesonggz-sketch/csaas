#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

repo_root="$(git rev-parse --show-toplevel)"

cd "$repo_root" || exit 1
node backend/scripts/detect-orm-risk-changes.js --pre-push
orm_risk_status=$?

if [ "$orm_risk_status" -eq 10 ]; then
  echo "[husky] ORM 高风险 push 改动 detected; running full ORM guards"
  npm --workspace backend run orm:guard:full || exit 1
elif [ "$orm_risk_status" -ne 0 ]; then
  exit "$orm_risk_status"
fi
