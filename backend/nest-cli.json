{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      {
        "include": "modules/applicability-engine/seeds/data/**/*",
        "outDir": "dist/src"
      },
      {
        "include": "modules/case-import-orchestrator/services/taxonomy-classification/rulebooks/manifests/**/*",
        "outDir": "dist/src"
      }
    ]
  }
}
