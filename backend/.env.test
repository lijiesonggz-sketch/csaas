# E2E Test Environment Configuration
NODE_ENV=test
PORT=3000
FRONTEND_URL=http://localhost:3001

# Test Database (using separate database for tests)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=csaas_test

# Redis (can use same redis instance)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AI APIs (not needed for most tests, but required for app init)
OPENAI_API_KEY=test_key
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
OPENAI_MODEL=glm-4.7

ANTHROPIC_API_KEY=test_key
ANTHROPIC_BASE_URL=https://as.imds.ai/api
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

TONGYI_API_KEY=test_key
TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TONGYI_MODEL=qwen3-max

DASHSCOPE_API_KEY=test_key
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# Test timeouts
CLUSTERING_GENERATION_TIMEOUT=900000
MODEL_GENERATION_TIMEOUT=900000
